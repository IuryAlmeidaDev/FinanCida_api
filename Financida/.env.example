DATABASE_URL="postgres://financida:financida_password@localhost:5432/financida"
SUPABASE_URL="https://seu-projeto.supabase.co"
SUPABASE_ANON_KEY="sua-anon-key"

# Opcional para upload de avatar e rotinas administrativas de auth
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
